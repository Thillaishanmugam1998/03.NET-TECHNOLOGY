{
  /*
    appsettings.Development.json
    ============================================================
    Loaded ONLY when  ASPNETCORE_ENVIRONMENT = "Development"
    Values here OVERRIDE appsettings.json.

    In development we want:
      • Verbose (Debug) logging so we can diagnose problems easily
      • Swagger UI visible
      • Detailed error pages
  */

  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "EmployeeAPI": "Debug"
    }
  },

  "AppSettings": {
    "AppName": "Employee Management API [DEV]",
    "ShowDetailedErrors": true
  }
}