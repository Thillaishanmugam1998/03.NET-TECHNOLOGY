{
  /*
    appsettings.Staging.json
    ============================================================
    Loaded ONLY when  ASPNETCORE_ENVIRONMENT = "Staging"
    Values here OVERRIDE appsettings.json.

    Staging is a "pre-production" environment that mirrors
    production as closely as possible, but is used for final
    testing before a release goes live.

    In staging we want:
      • Warning-level logging (less noise than Dev, more than Prod)
      • No detailed error pages (mimic production behaviour)
      • Swagger can still be enabled to assist QA testers
  */

  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "EmployeeAPI": "Information"
    }
  },

  "AppSettings": {
    "AppName": "Employee Management API [STAGING]",
    "ShowDetailedErrors": false
  }
}