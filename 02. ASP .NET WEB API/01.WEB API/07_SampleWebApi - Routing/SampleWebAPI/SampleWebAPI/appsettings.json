{
  // ── API Key ───────────────────────────────────────────────────────────────
  // BasicAuthHandler reads ApiSettings:ApiKey and compares it to the password
  // sent in the Authorization: Basic <base64(username:password)> header.
  //
  // ⚠️  Change this value before deploying to production.
  //     In production, store this in an environment variable or Azure Key Vault
  //     — never commit a real secret to source control.
  "ApiSettings": {
    "ApiKey": "MySuperSecretKey123!"
  },

  // ── Logging ───────────────────────────────────────────────────────────────
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // ── Hosts ─────────────────────────────────────────────────────────────────
  "AllowedHosts": "*"
}