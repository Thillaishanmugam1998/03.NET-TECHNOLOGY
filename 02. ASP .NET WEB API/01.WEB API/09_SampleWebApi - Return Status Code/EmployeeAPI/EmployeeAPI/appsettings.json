{
  /*
    appsettings.json  –  Default / Production configuration
    =========================================================
    This file is loaded in ALL environments.
    Environment-specific files (appsettings.Development.json, etc.)
    override values defined here.
  */

  "Logging": {
    "LogLevel": {
      /*
        Default   – minimum level for all categories not listed below
        Microsoft – ASP.NET Core internal logs (routing, hosting, etc.)
        Warning   – only log Warning, Error, Critical for Microsoft internals
      */
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  /*
    AllowedHosts  –  restricts which Host headers the server accepts.
    "*" means accept requests from any host (fine for development/demo).
    In production, set this to your actual domain:  "api.mycompany.com"
  */
  "AllowedHosts": "*",

  /*
    AppSettings  –  custom key/value pairs for our application.
    You can read these in code via:  IConfiguration["AppSettings:AppName"]
  */
  "AppSettings": {
    "AppName": "Employee Management API",
    "Version": "1.0.0",
    "MaxPageSize": 100
  }
}