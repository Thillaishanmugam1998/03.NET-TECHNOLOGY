{
  /*
    Properties/launchSettings.json
    ============================================================
    This file is used by Visual Studio / VS Code / dotnet CLI
    to configure how the app is launched LOCALLY.

    It is NOT deployed to a server – it is a developer convenience file.

    Two profiles are defined:
      1. "https"  – Launch with HTTPS (recommended)
      2. "http"   – Launch with HTTP only (simpler, no certificate needed)
  */

  "$schema": "http://json.schemastore.org/launchsettings.json",

  "profiles": {

    "https": {
      /*
        applicationUrl  –  the URLs the Kestrel web server listens on
        ASPNETCORE_ENVIRONMENT = "Development"  →  loads appsettings.Development.json
        launchBrowser   –  automatically open the browser when you press F5
        launchUrl       –  open this path in the browser (Swagger UI root)
      */
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "launchUrl": "scalar/v1",
      "applicationUrl": "https://localhost:7100;http://localhost:5100",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },

    "http": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "launchUrl": "scalar/v1",
      "applicationUrl": "http://localhost:5100",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },

    "Staging": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "https://localhost:7200;http://localhost:5200",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Staging"
      }
    }
  }
}